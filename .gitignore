# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright MCP 로그 및 스크린샷 (자동 생성 파일)
.playwright-mcp/

# Claude 로컬 설정 (민감 정보 포함 가능)
.claude/settings.local.json
